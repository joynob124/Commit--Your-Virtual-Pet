# API Configuration
# For local development, set to your backend server URL (e.g., http://localhost:3001)
# For Vercel deployment, leave empty or set to empty string to use relative paths
VITE_API_BASE_URL=

# Turso Database Configuration (for backend)
# Get these from https://turso.tech
TURSO_DATABASE_URL=your_turso_database_url_here
TURSO_AUTH_TOKEN=your_turso_auth_token_here
